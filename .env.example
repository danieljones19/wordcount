# Single group (simplest)
GROUPME_BOT_ID=your_bot_id_here

# Multi-group support (optional). If set, this overrides GROUPME_BOT_ID per group.
# Format: group_id_1:bot_id_1,group_id_2:bot_id_2
GROUPME_BOT_ID_MAP=

# Required for accurate likes/member lookups
GROUPME_ACCESS_TOKEN=your_access_token_here

# Optional tuning
BOT_DB_PATH=wordcount.db
MAX_REPLY_LEN=900
SYNC_INTERVAL_SECONDS=300
MAX_SYNC_PAGES=25
MEMBER_CACHE_SECONDS=600
